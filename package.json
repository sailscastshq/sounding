{
  "name": "sounding",
  "version": "0.2.0",
  "description": "Testing framework for Sails applications and The Boring JavaScript Stack.",
  "main": "index.js",
  "bin": {
    "sounding": "bin/sounding.js"
  },
  "workspaces": [
    "plugins/*"
  ],
  "license": "MIT",
  "keywords": [
    "sails",
    "testing",
    "node:test",
    "playwright",
    "tbjs"
  ],
  "files": [
    "bin",
    "index.js",
    "lib",
    "README.md",
    "RESEARCH.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "typecheck": "tsc -p jsconfig.json --noEmit"
  },
  "sails": {
    "isHook": true,
    "hookName": "sounding"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sailscastshq/sounding.git"
  },
  "homepage": "https://github.com/sailscastshq/sounding#readme",
  "bugs": {
    "url": "https://github.com/sailscastshq/sounding/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "sails": "^1.5.18",
    "sails-hook-orm": "^4.0.3",
    "sails-hook-sockets": "^3.0.2",
    "sails-sqlite": "^0.2.6",
    "socket.io-client": "^4.8.3",
    "typescript": "^6.0.3"
  }
}
